# Routing support for static webapp deployment (Apache)
#
# Why:
# - iOS home screen shortcuts may drop query params.
# - We therefore support path-based routes like /kiosk/<station> and /station/<station>.
# - These routes must resolve to index.html so the app can parse window.location.pathname.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Prefer precompressed GLB payloads for much faster model downloads.
  RewriteCond %{REQUEST_URI} \.glb$ [NC]
  RewriteCond %{HTTP:Accept-Encoding} br [NC]
  RewriteCond %{REQUEST_FILENAME}.br -f
  RewriteRule ^ %{REQUEST_URI}.br [L]

  RewriteCond %{REQUEST_URI} \.glb$ [NC]
  RewriteCond %{HTTP:Accept-Encoding} gzip [NC]
  RewriteCond %{REQUEST_FILENAME}.gz -f
  RewriteRule ^ %{REQUEST_URI}.gz [L]

  # Serve existing files/directories directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # /issue is legacy; redirect to /feedback (new).
  RewriteRule ^issue/?$ /feedback/ [R=301,L]
  # Keep /feedback/ SPA entry stable.
  RewriteRule ^feedback$ /feedback/ [R=301,L]

  # Custom 404 document (static hosts that respect it).
  ErrorDocument 404 /404.html

  # Path-based station/kiosk routes (used especially for iOS home-screen mode).
  RewriteRule ^kiosk/[^/]+/?$ /index.html [L]
  RewriteRule ^station/[^/]+/?$ /index.html [L]
  # Short station route for QR codes: /s/<station>
  RewriteRule ^s/[^/]+/?$ /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.glb\.br$">
    Header set Content-Encoding br
    Header set Content-Type model/gltf-binary
    Header append Vary Accept-Encoding
  </FilesMatch>
  <FilesMatch "\.glb\.gz$">
    Header set Content-Encoding gzip
    Header set Content-Type model/gltf-binary
    Header append Vary Accept-Encoding
  </FilesMatch>
</IfModule>
